[{"data":1,"prerenderedAt":157},["ShallowReactive",2],{"navigation":3,"about":22,"mdc--to44gx-key":42},[4],{"title":5,"path":6,"stem":7,"children":8,"page":21},"Blog","\u002Fblog","blog",[9,13,17],{"title":10,"path":11,"stem":12},"用 Nuxt 初始化个人简历与技术博客","\u002Fblog\u002Fbuilding-my-personal-site-with-nuxt","blog\u002Fbuilding-my-personal-site-with-nuxt",{"title":14,"path":15,"stem":16},"前端工程化笔记：从可运行到可维护","\u002Fblog\u002Ffrontend-engineering-notes","blog\u002Ffrontend-engineering-notes",{"title":18,"path":19,"stem":20},"项目复盘模板：把经历写成作品","\u002Fblog\u002Fproject-review-template","blog\u002Fproject-review-template",false,{"id":23,"title":24,"body":25,"content":26,"description":27,"extension":28,"images":29,"meta":36,"navigation":37,"path":38,"seo":39,"stem":40,"__hash__":41},"about\u002Fabout.yml","个人简历",null,"你好，我是 **你的名字**，一名前端 \u002F 全栈开发者。我的工作重点是把复杂需求拆解成清晰的产品体验和稳定的工程实现，关注代码质量、交付效率和长期可维护性。\n\n## 技术栈\n\n- 前端：Vue、Nuxt、TypeScript、Tailwind CSS \u002F Nuxt UI\n- 工程化：Vite、ESLint、pnpm、自动化脚本、CI\u002FCD\n- 服务端：Node.js、REST API、数据库基础、部署与监控\n- 方法：需求拆解、组件设计、性能优化、项目复盘\n\n## 工作方式\n\n我习惯先明确问题边界和验收标准，再推进设计、开发、测试和上线。面对不确定需求时，会优先交付可验证的最小版本，并在真实反馈中持续迭代。\n\n## 近期关注\n\n最近主要关注 Nuxt 生态、内容型站点、AI 辅助开发、前端工程质量和个人知识管理。我会把相关实践记录在 [博客](\u002Fblog) 中。\n\n## 联系方式\n\n欢迎通过 [邮件](mailto:hello@example.com) 或 GitHub 联系我。上线前请把 `hello@example.com`、`your-name` 和头像链接替换为你的真实信息。\n","这里是你的个人介绍、技能栈、工作经历和项目方向。把占位内容替换为真实信息后即可作为在线简历使用。","yml",[30,33],{"src":31,"alt":32},"https:\u002F\u002Fimages.unsplash.com\u002Fphoto-1744877478622-a78c7a3336f6?q=80&w=1587&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D","工作区照片",{"src":34,"alt":35},"https:\u002F\u002Fimages.unsplash.com\u002Fphoto-1744429523595-2c06b8611242?q=80&w=1587&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D","生活与学习照片",{},true,"\u002Fabout",{"title":24,"description":27},"about","dBK9Tc95fuvJCrTuBnyqxyhx2itWT0yTitsDbB3FfaQ",{"data":43,"body":44},{},{"type":45,"childre